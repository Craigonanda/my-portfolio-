# M-Pesa Daraja API (never commit real values — copy this file to .env)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
# Get your passkey from the Daraja portal (sandbox or production app)
MPESA_PASSKEY=your_passkey_here
MPESA_ENV=sandbox

# M-Pesa callback is built from ZROK_PUBLIC_URL in server/config.py
# Optional override:
# MPESA_CALLBACK_URL=https://your-tunnel-url.example.com/api/mpesa/callback

# Optional: powers smarter chat replies
OPENAI_API_KEY=

# Flask
FLASK_SECRET_KEY=change-me-in-production
PORT=5000
